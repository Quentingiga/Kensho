{
  "expo": {
    "name": "Kensho",
    "slug": "kensho",
    "androidStatusBar": {
      "hidden": true,
      "backgroundColor": "#ffffff"
    },
    "androidNavigationBar": {
      "visible": "sticky-immersive"
    },
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sololevelingapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.qchesniercore.kensho"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "SystemWidget",
              "label": "Kensho Système",
              "minWidth": "250dp",
              "minHeight": "150dp",
              "description": "Statut du Réceptacle et Quêtes",
              "previewImage": "./assets/images/icon.png"
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "28aad6a2-b226-414a-9135-7b8469b7396d"
      }
    },
    "owner": "qchesnier-core"
  }
}
